generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String              @id @default(uuid())
  name               String              @unique
  slug               String              @unique
  logoUrl            String?
  address            String?
  partitaIva         String?
  maxAgents          Int                 @default(100)
  planType           String              @default("TRIAL")
  trialEndsAt        DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  clockInRadius      Int                 @default(500)
  lat                Float?
  lng                Float?
  primaryColor       String              @default("#4f46e5")
  absences           Absence[]
  announcements      Announcement[]
  agendaEntries      AgendaEntry[]
  agentBalances      AgentBalance[]
  agentRequests      AgentRequest[]
  auditLogs          AuditLog[]
  certifiedDocuments CertifiedDocument[]
  clockRecords       ClockRecord[]
  emergencyAlerts    EmergencyAlert[]
  globalSettings     GlobalSettings?
  monthStatuses      MonthStatus[]
  notifications      Notification[]
  patrolTemplates    PatrolTemplate[]
  pecSettings        PecSettings?
  rotationGroups     RotationGroup[]
  schools            School[]
  serviceCategories  ServiceCategory[]
  serviceTypes       ServiceType[]
  shifts             Shift[]
  shiftSwapRequests  ShiftSwapRequest[]
  users              User[]
  vehicles           Vehicle[]
}

model User {
  id                       String    @id @default(uuid())
  tenantId                 String?
  matricola                String
  name                     String
  isSuperAdmin             Boolean   @default(false)
  email                    String?   @unique
  phone                    String?
  password                 String
  role                     String    @default("AGENTE")
  isUfficiale              Boolean   @default(false)
  qualifica                String?   @default("Agente di P.L.")
  gradoLivello             Int       @default(13)
  massimale                Int       @default(8)
  squadra                  String?
  servizio                 String?
  rotationGroupId          String?
  defaultServiceCategoryId String?
  defaultServiceTypeId     String?
  fixedRestDay             Int?
  forcePasswordChange      Boolean   @default(true)
  telegramChatId           String?
  telegramLinkCode         String?
  telegramLinkExpires      DateTime?
  dataAssunzione           DateTime?
  dataDiNascita            DateTime?
  scadenzaPatente          DateTime?
  scadenzaPortoArmi        DateTime?
  tipoContratto            String?
  noteInterne              String?
  defaultPartnerIds        String[]
  fixedServiceDays         String[]
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  canConfigureSystem       Boolean   @default(false)
  canManageShifts          Boolean   @default(false)
  canManageUsers           Boolean   @default(false)
  canVerifyClockIns        Boolean   @default(false)
  isActive                 Boolean   @default(true)

  // Diritti & Agevolazioni
  hasL104                Boolean            @default(false)
  l104Assistiti          Int                @default(1)
  hasStudyLeave          Boolean            @default(false)
  hasParentalLeave       Boolean            @default(false)
  hasChildSicknessLeave  Boolean            @default(false)
  absences               Absence[]
  agendaEntries          AgendaEntry[]      @relation("agendaEntries")
  agentBalances          AgentBalance[]     @relation("AgentBalances")
  agentRequests          AgentRequest[]     @relation("AgentRequests")
  receivedAlerts         AlertRecipient[]   @relation("AlertRecipientUser")
  clockRecords           ClockRecord[]
  adminAlerts            EmergencyAlert[]   @relation("AdminAlerts")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  shifts                 Shift[]
  sentSwaps              ShiftSwapRequest[] @relation("SentSwaps")
  receivedSwaps          ShiftSwapRequest[] @relation("ReceivedSwaps")
  defaultServiceCategory ServiceCategory?   @relation("DefaultCategory", fields: [defaultServiceCategoryId], references: [id])
  defaultServiceType     ServiceType?       @relation("DefaultType", fields: [defaultServiceTypeId], references: [id])
  rotationGroup          RotationGroup?     @relation(fields: [rotationGroupId], references: [id])
  tenant                 Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patrolTemplates        PatrolTemplate[]   @relation("PatrolMembers")

  @@unique([tenantId, matricola])
}

model Absence {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String
  date      DateTime
  code      String
  source    String   @default("MANUAL")
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, tenantId])
}

model Shift {
  id                 String             @id @default(uuid())
  tenantId           String?
  userId             String
  date               DateTime
  type               String             @default("REP 22-07")
  repType            String?
  isSyncedToVerbatel Boolean            @default(false)
  timeRange          String?
  serviceCategoryId  String?
  serviceTypeId      String?
  vehicleId          String?
  serviceDetails     String?
  patrolGroupId      String?
  durationHours      Float              @default(6)
  overtimeHours      Float              @default(0)
  createdAt          DateTime           @default(now())
  serviceCategory    ServiceCategory?   @relation(fields: [serviceCategoryId], references: [id])
  serviceType        ServiceType?       @relation(fields: [serviceTypeId], references: [id])
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?           @relation(fields: [vehicleId], references: [id])
  swaps              ShiftSwapRequest[]

  @@unique([userId, date, tenantId])
}

model PatrolTemplate {
  id                String           @id @default(uuid())
  tenantId          String?
  name              String
  serviceCategoryId String?
  serviceTypeId     String?
  vehicleId         String?
  preferredShift    String?          @default("ALL")
  createdAt         DateTime         @default(now())
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceType       ServiceType?     @relation(fields: [serviceTypeId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id])
  members           User[]           @relation("PatrolMembers")

  @@unique([name, tenantId])
}

model ServiceCategory {
  id              String           @id @default(uuid())
  tenantId        String?
  name            String
  orderIndex      Int              @default(0)
  patrolTemplates PatrolTemplate[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  types           ServiceType[]
  shifts          Shift[]
  defaultUsers    User[]           @relation("DefaultCategory")

  @@unique([name, tenantId])
}

model ServiceType {
  id              String           @id @default(uuid())
  tenantId        String?
  categoryId      String
  name            String
  patrolTemplates PatrolTemplate[]
  category        ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts          Shift[]
  defaultUsers    User[]           @relation("DefaultType")

  @@unique([categoryId, name])
}

model Vehicle {
  id                    String           @id @default(uuid())
  tenantId              String?
  name                  String
  scadenzaAssicurazione DateTime?
  scadenzaBollo         DateTime?
  scadenzaRevisione     DateTime?
  stato                 String           @default("ATTIVO")
  targa                 String?
  patrolTemplates       PatrolTemplate[]
  shifts                Shift[]
  tenant                Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
}

model RotationGroup {
  id         String   @id @default(uuid())
  tenantId   String?
  name       String
  pattern    String
  mStartTime String   @default("07:00")
  mEndTime   String   @default("13:00")
  pStartTime String   @default("13:00")
  pEndTime   String   @default("19:00")
  startDate  DateTime @default(now())
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User[]

  @@unique([name, tenantId])
}

model GlobalSettings {
  id                  Int     @id @default(autoincrement())
  tenantId            String? @unique
  minUfficiali        Int     @default(1)
  usaProporzionale    Boolean @default(true)
  annoCorrente        Int     @default(2026)
  meseCorrente        Int     @default(4)
  massimaleAgente     Int     @default(8)
  massimaleUfficiale  Int     @default(8)
  distaccoMinimo      Int     @default(2)
  permettiConsecutivi Boolean @default(false)

  bpTurnoContinuato Float @default(7.0)
  bpStaccoMinTurno1 Float @default(6.0)
  bpStaccoMaxPausa  Float @default(2.0)
  bpStaccoMinTurno2 Float @default(2.0)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MonthStatus {
  id          String  @id @default(uuid())
  tenantId    String?
  month       Int
  year        Int
  isPublished Boolean @default(false)
  isLocked    Boolean @default(false)
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([month, year, tenantId])
}

model AgendaEntry {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String
  date      DateTime
  code      String
  label     String
  hours     Float?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation("agendaEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, code, tenantId])
  @@index([userId])
}

model PecSettings {
  id       Int     @id @default(autoincrement())
  tenantId String? @unique
  host     String  @default("")
  port     String  @default("465")
  user     String  @default("")
  pass     String  @default("")
  fromAddr String  @default("")
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  adminId    String
  adminName  String?
  action     String
  targetId   String?
  targetName String?
  details    String
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model EmergencyAlert {
  id         String           @id @default(uuid())
  tenantId   String?
  adminId    String
  date       DateTime         @default(now())
  message    String
  status     String           @default("PENDING")
  lat        Float?
  lng        Float?
  recipients AlertRecipient[]
  admin      User             @relation("AdminAlerts", fields: [adminId], references: [id])
  tenant     Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AlertRecipient {
  id      String         @id @default(uuid())
  alertId String
  userId  String
  status  String         @default("SENT")
  ackedAt DateTime?
  alert   EmergencyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user    User           @relation("AlertRecipientUser", fields: [userId], references: [id])
}

model ShiftSwapRequest {
  id           String   @id @default(uuid())
  tenantId     String?
  requesterId  String
  targetUserId String?
  shiftId      String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  acceptedById String?
  message      String?
  requester    User     @relation("SentSwaps", fields: [requesterId], references: [id])
  shift        Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("ReceivedSwaps", fields: [targetUserId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([targetUserId])
  @@index([tenantId, status])
}

model AgentRequest {
  id         String    @id @default(uuid())
  tenantId   String?
  userId     String
  date       DateTime
  endDate    DateTime?
  startTime  String?
  endTime    String?
  hours      Float?
  code       String
  notes      String?
  status     String    @default("PENDING")
  reviewedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation("AgentRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AgentBalance {
  id       String          @id @default(uuid())
  tenantId String?
  userId   String
  year     Int
  tenant   Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User            @relation("AgentBalances", fields: [userId], references: [id], onDelete: Cascade)
  details  BalanceDetail[]

  @@unique([userId, year, tenantId])
}

model BalanceDetail {
  id           String       @id @default(uuid())
  balanceId    String
  code         String
  label        String?
  initialValue Float        @default(0)
  unit         String       @default("DAYS")
  balance      AgentBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  @@unique([balanceId, code])
}

model Notification {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String
  title      String
  message    String
  type       String   @default("INFO")
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  metadata   String?
  isArchived Boolean  @default(false)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClockRecord {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String
  timestamp  DateTime @default(now())
  type       String
  lat        Float?
  lng        Float?
  accuracy   Float?
  isVerified Boolean  @default(true)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId, timestamp])
}

model School {
  id        String           @id @default(uuid())
  tenantId  String?
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules SchoolSchedule[]

  @@unique([name, tenantId])
}

model SchoolSchedule {
  id                String  @id @default(uuid())
  schoolId          String
  dayOfWeek         Int
  entranceTime      String  @default("07:45-08:30")
  exitTime          String  @default("13:00-14:00")
  afternoonExitTime String?
  school            School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dayOfWeek])
}

model CertifiedDocument {
  id         String   @id @default(uuid())
  tenantId   String?
  hash       String   @unique
  type       String
  issuerId   String
  issuerName String
  issuedAt   DateTime @default(now())
  metadata   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([hash, tenantId])
}

model Announcement {
  id           String             @id @default(uuid())
  tenantId     String?
  authorId     String
  authorName   String             @default("Comando")
  title        String
  body         String
  priority     String             @default("NORMAL")
  requiresRead Boolean            @default(false)
  isPinned     Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reads        AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId], name: "announcementId_userId")
}

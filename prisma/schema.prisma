  updatedAt                DateTime    @updatedAt

  tenant                   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checkpoint               Checkpoint  @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([checkpointId])
  @@index([targa])
}

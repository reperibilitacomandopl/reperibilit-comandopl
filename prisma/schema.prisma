generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String                   @id @default(uuid())
  name                    String                   @unique
  slug                    String                   @unique
  logoUrl                 String?
  address                 String?
  partitaIva              String?
  maxAgents               Int                      @default(100)
  planType                String                   @default("TRIAL")
  trialEndsAt             DateTime?
  serviceStartDate        DateTime?
  serviceEndDate          DateTime?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  clockInRadius           Int                      @default(500)
  lat                     Float?
  lng                     Float?
  primaryColor            String                   @default("#4f46e5")
  absences                Absence[]
  agendaEntries           AgendaEntry[]
  agentBalances           AgentBalance[]
  agentRequests           AgentRequest[]
  announcements           Announcement[]
  armors                  Armor[]
  auditLogs               AuditLog[]
  certifiedDocuments      CertifiedDocument[]
  chatMessages            ChatMessage[]
  clockRecords            ClockRecord[]
  customHolidays          CustomHoliday[]
  dailyOdsNotes           DailyOdsNote[]
  emergencyAlerts         EmergencyAlert[]
  geofenceZones           GeofenceZone[]
  globalSettings          GlobalSettings?
  holidayRotationGroups   HolidayRotationGroup[]
  interventions           Intervention[]
  locationHistory         LocationHistory[]
  monthStatuses           MonthStatus[]
  municipalities          Municipality[]
  notifications           Notification[]
  patrolTemplates         PatrolTemplate[]
  pecSettings             PecSettings?
  radios                  Radio[]
  rotationGroups          RotationGroup[]
  schools                 School[]
  serviceCategories       ServiceCategory[]
  serviceTypes            ServiceType[]
  shifts                  Shift[]
  ShiftRule               ShiftRule[]
  shiftSwapRequests       ShiftSwapRequest[]
  streets                 Street[]
  trainingRecords         TrainingRecord[]
  users                   User[]
  accidentReports         AccidentReport[]
  serviceReports          ServiceReport[]
  userDocuments           UserDocument[]
  vacationPlans           VacationPlan[]
  vacationRotationGroups  VacationRotationGroup[]
  vacationRotationPeriods VacationRotationPeriod[]
  vacationSwapRequests    VacationSwapRequest[]
  vehicles                Vehicle[]
  vehicleBrands           VehicleBrand[]
  vehicleTypes            VehicleType[]
  violations              Violation[]
  weapons                 Weapon[]
  SpecialEvent            SpecialEvent[]
  EventAssignment         EventAssignment[]
  checkpoints             Checkpoint[]
  checkedVehicles         CheckedVehicle[]
}

model Municipality {
  id             String   @id @default(uuid())
  tenantId       String?
  codiceBelfiore String
  denominazione  String
  provincia      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model VehicleType {
  id                String   @id @default(uuid())
  tenantId          String?
  codice            String
  descrizione       String
  targaObbligatoria Boolean  @default(false)
  coob              Boolean  @default(false)
  decurtazionePunti Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model VehicleBrand {
  id          String   @id @default(uuid())
  tenantId    String?
  codice      String
  descrizione String
  nazione     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Street {
  id               String   @id @default(uuid())
  tenantId         String?
  codice           String?
  denominazione    String
  chiave           String?
  comune           String?
  zona             String?
  enteProprietario String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chiave])
  @@index([denominazione])
}

model User {
  id                        String                    @id @default(uuid())
  tenantId                  String?
  matricola                 String
  name                      String
  isSuperAdmin              Boolean                   @default(false)
  email                     String?                   @unique
  phone                     String?
  password                  String
  role                      String                    @default("AGENTE")
  isUfficiale               Boolean                   @default(false)
  qualifica                 String?                   @default("Agente di P.L.")
  gradoLivello              Int                       @default(13)
  massimale                 Int                       @default(8)
  squadra                   String?
  servizio                  String?
  rotationGroupId           String?
  defaultServiceCategoryId  String?
  defaultServiceTypeId      String?
  fallbackServiceCategoryId String?
  fixedRestDay              Int?
  dynamicRestStartDay       Int?
  forcePasswordChange       Boolean                   @default(true)
  telegramChatId            String?
  telegramLinkCode          String?
  telegramLinkExpires       DateTime?
  dataAssunzione            DateTime?
  scadenzaPatente           DateTime?
  scadenzaPortoArmi         DateTime?
  noteInterne               String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  canConfigureSystem        Boolean                   @default(false)
  canManageShifts           Boolean                   @default(false)
  canManageUsers            Boolean                   @default(false)
  canVerifyClockIns         Boolean                   @default(false)
  isActive                  Boolean                   @default(true)
  dataDiNascita             DateTime?
  defaultPartnerIds         String[]
  fixedServiceDays          String[]
  tipoContratto             String?
  hasChildSicknessLeave     Boolean                   @default(false)
  hasL104                   Boolean                   @default(false)
  hasParentalLeave          Boolean                   @default(false)
  hasStudyLeave             Boolean                   @default(false)
  l104Assistiti             Int                       @default(1)
  lastLat                   Float?
  lastLng                   Float?
  lastSeenAt                DateTime?
  gpsAcceptedAt             DateTime?
  gpsConsent                Boolean                   @default(false)
  privacyAcceptedAt         DateTime?
  privacyConsent            Boolean                   @default(false)
  twoFactorEnabled          Boolean                   @default(false)
  twoFactorSecret           String?
  twoFactorBackupCodes      String[]                  @default([])
  trustedIps                String[]                  @default([])
  telegramOptIn             Boolean                   @default(true)
  deletedAt                 DateTime?
  failedLoginAttempts       Int                       @default(0)
  lockoutUntil              DateTime?
  lockoutReason             String?
  unlockedBy                String?
  resetPasswordToken        String?                   @unique
  resetPasswordExpires      DateTime?
  absences                  Absence[]
  accidentReports           AccidentReport[]          @relation("AccidentReportingOfficer")
  secondOfficerAccidents    AccidentReport[]          @relation("AccidentSecondOfficer")
  supervisedAccidents       AccidentReport[]          @relation("AccidentSupervisor")
  declarations              AccidentDeclaration[]     @relation("DeclarationRecordedBy")
  surveys                   AccidentSurvey[]          @relation("SurveySurveyedBy")
  accidentAuditLogs         AccidentAuditLog[]
  serviceReports            ServiceReport[]
  agendaEntries             AgendaEntry[]             @relation("agendaEntries")
  agentBalances             AgentBalance[]            @relation("AgentBalances")
  agentRequests             AgentRequest[]            @relation("AgentRequests")
  receivedAlerts            AlertRecipient[]          @relation("AlertRecipientUser")
  announcements             Announcement[]
  armors                    Armor[]                   @relation("ArmorAssegnatario")
  sentMessages              ChatMessage[]             @relation("SentMessages")
  clockRecords              ClockRecord[]
  customHolidayAssignments  CustomHolidayAssignment[]
  adminAlerts               EmergencyAlert[]          @relation("AdminAlerts")
  interventions             Intervention[]            @relation("UserInterventions")
  locationHistory           LocationHistory[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  radios                    Radio[]                   @relation("RadioAssegnatario")
  shifts                    Shift[]
  sentSwaps                 ShiftSwapRequest[]        @relation("SentSwaps")
  receivedSwaps             ShiftSwapRequest[]        @relation("ReceivedSwaps")
  trainingRecords           TrainingRecord[]
  defaultServiceCategory    ServiceCategory?          @relation("DefaultCategory", fields: [defaultServiceCategoryId], references: [id])
  defaultServiceType        ServiceType?              @relation("DefaultType", fields: [defaultServiceTypeId], references: [id])
  rotationGroup             RotationGroup?            @relation(fields: [rotationGroupId], references: [id])
  tenant                    Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents                 UserDocument[]
  vacationPlans             VacationPlan[]
  sentVacationSwaps         VacationSwapRequest[]     @relation("SentVacationSwaps")
  receivedVacationSwaps     VacationSwapRequest[]     @relation("ReceivedVacationSwaps")
  violations                Violation[]               @relation("UserViolations")
  weapons                   Weapon[]                  @relation("WeaponAssegnatario")
  holidayRotationGroups     HolidayRotationGroup[]    @relation("HolidayRotationGroupMembers")
  patrolTemplates           PatrolTemplate[]          @relation("PatrolMembers")
  vacationRotationGroups    VacationRotationGroup[]   @relation("VacationRotationGroupMembers")
  eventAssignments          EventAssignment[]         @relation("EventAssignments")
  checkpoints               Checkpoint[]              @relation("CheckpointOperator")

  @@unique([tenantId, matricola])
}

model Absence {
  id        String    @id @default(uuid())
  tenantId  String?
  userId    String
  date      DateTime
  code      String
  source    String    @default("MANUAL")
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, tenantId])
}

model Shift {
  id                 String             @id @default(uuid())
  tenantId           String?
  userId             String
  date               DateTime
  type               String             @default("REP 22-07")
  repType            String?
  isSyncedToVerbatel Boolean            @default(false)
  timeRange          String?
  serviceCategoryId  String?
  serviceTypeId      String?
  vehicleId          String?
  serviceDetails     String?
  patrolGroupId      String?
  durationHours      Float              @default(6)
  overtimeHours      Float              @default(0)
  createdAt          DateTime           @default(now())
  deletedAt          DateTime?
  radioId            String?
  armorId            String?
  weaponId           String?
  armor              Armor?             @relation(fields: [armorId], references: [id])
  radio              Radio?             @relation(fields: [radioId], references: [id])
  serviceCategory    ServiceCategory?   @relation(fields: [serviceCategoryId], references: [id])
  serviceType        ServiceType?       @relation(fields: [serviceTypeId], references: [id])
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?           @relation(fields: [vehicleId], references: [id])
  weapon             Weapon?            @relation(fields: [weaponId], references: [id])
  swaps              ShiftSwapRequest[]
  serviceReports     ServiceReport[]

  @@unique([userId, date, tenantId])
}

model PatrolTemplate {
  id                String           @id @default(uuid())
  tenantId          String?
  name              String
  serviceCategoryId String?
  serviceTypeId     String?
  vehicleId         String?
  preferredShift    String?          @default("ALL")
  createdAt         DateTime         @default(now())
  radioId           String?
  armorId           String?
  weaponId          String?
  armor             Armor?           @relation(fields: [armorId], references: [id])
  radio             Radio?           @relation(fields: [radioId], references: [id])
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceType       ServiceType?     @relation(fields: [serviceTypeId], references: [id])
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?         @relation(fields: [vehicleId], references: [id])
  weapon            Weapon?          @relation(fields: [weaponId], references: [id])
  members           User[]           @relation("PatrolMembers")

  @@unique([name, tenantId])
}

model ServiceCategory {
  id              String           @id @default(uuid())
  tenantId        String?
  name            String
  orderIndex      Int              @default(0)
  patrolTemplates PatrolTemplate[]
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  types           ServiceType[]
  shifts          Shift[]
  defaultUsers    User[]           @relation("DefaultCategory")

  @@unique([name, tenantId])
}

model ServiceType {
  id              String           @id @default(uuid())
  tenantId        String?
  categoryId      String
  name            String
  patrolTemplates PatrolTemplate[]
  category        ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts          Shift[]
  defaultUsers    User[]           @relation("DefaultType")

  @@unique([categoryId, name])
}

model Vehicle {
  id                    String           @id @default(uuid())
  tenantId              String?
  name                  String
  scadenzaAssicurazione DateTime?
  scadenzaBollo         DateTime?
  scadenzaRevisione     DateTime?
  stato                 String           @default("ATTIVO")
  targa                 String?
  patrolTemplates       PatrolTemplate[]
  shifts                Shift[]
  eventAssignments      EventAssignment[]
  tenant                Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
}

model Radio {
  id                  String           @id @default(uuid())
  tenantId            String?
  name                String
  modello             String?
  seriale             String?
  stato               String           @default("ATTIVO")
  assegnazioneFissaId String?
  dataAssegnazione    DateTime?
  cambioBatteria      DateTime?
  patrolTemplates     PatrolTemplate[]
  assegnatario        User?            @relation("RadioAssegnatario", fields: [assegnazioneFissaId], references: [id])
  tenant              Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shifts              Shift[]

  @@unique([name, tenantId])
}

model Weapon {
  id                  String           @id @default(uuid())
  tenantId            String?
  name                String
  modello             String?
  matricola           String?
  stato               String           @default("ATTIVO")
  assegnazioneFissaId String?
  dataAssegnazione    DateTime?
  note                String?
  patrolTemplates     PatrolTemplate[]
  shifts              Shift[]
  assegnatario        User?            @relation("WeaponAssegnatario", fields: [assegnazioneFissaId], references: [id])
  tenant              Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
}

model Armor {
  id                  String           @id @default(uuid())
  tenantId            String?
  name                String
  modello             String?
  seriale             String?
  stato               String           @default("ATTIVO")
  assegnazioneFissaId String?
  dataAssegnazione    DateTime?
  scadenzaKevlar      DateTime?
  assegnatario        User?            @relation("ArmorAssegnatario", fields: [assegnazioneFissaId], references: [id])
  tenant              Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patrolTemplates     PatrolTemplate[]
  shifts              Shift[]

  @@unique([name, tenantId])
}

model RotationGroup {
  id         String   @id @default(uuid())
  tenantId   String?
  name       String
  pattern    String
  mStartTime String   @default("07:00")
  mEndTime   String   @default("13:00")
  pStartTime String   @default("13:00")
  pEndTime   String   @default("19:00")
  startDate  DateTime @default(now())
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User[]

  @@unique([name, tenantId])
}

model GlobalSettings {
  id                        Int     @id @default(autoincrement())
  tenantId                  String? @unique
  minUfficiali              Int     @default(1)
  usaProporzionale          Boolean @default(true)
  annoCorrente              Int     @default(2026)
  meseCorrente              Int     @default(4)
  massimaleAgente           Int     @default(8)
  massimaleUfficiale        Int     @default(8)
  distaccoMinimo            Int     @default(2)
  permettiConsecutivi       Boolean @default(false)
  bpStaccoMaxPausa          Float   @default(2.0)
  bpStaccoMinTurno1         Float   @default(6.0)
  bpStaccoMinTurno2         Float   @default(2.0)
  bpTurnoContinuato         Float   @default(7.0)
  gpsHistoryIntervalMinutes Int     @default(60)
  tenant                    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MonthStatus {
  id          String  @id @default(uuid())
  tenantId    String?
  month       Int
  year        Int
  isPublished Boolean @default(false)
  isLocked    Boolean @default(false)
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([month, year, tenantId])
}

model AgendaEntry {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String
  date      DateTime
  code      String
  label     String
  hours     Float?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation("agendaEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, code, tenantId])
  @@index([userId])
}

model PecSettings {
  id       Int     @id @default(autoincrement())
  tenantId String? @unique
  host     String  @default("")
  port     String  @default("465")
  user     String  @default("")
  pass     String  @default("")
  fromAddr String  @default("")
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String    @id @default(uuid())
  tenantId   String?
  adminId    String
  adminName  String?
  action     String
  targetId   String?
  targetName String?
  details    String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model EmergencyAlert {
  id         String           @id @default(uuid())
  tenantId   String?
  adminId    String
  date       DateTime         @default(now())
  message    String
  status     String           @default("PENDING")
  lat        Float?
  lng        Float?
  deletedAt  DateTime?
  recipients AlertRecipient[]
  admin      User             @relation("AdminAlerts", fields: [adminId], references: [id])
  tenant     Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AlertRecipient {
  id      String         @id @default(uuid())
  alertId String
  userId  String
  status  String         @default("SENT")
  ackedAt DateTime?
  alert   EmergencyAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user    User           @relation("AlertRecipientUser", fields: [userId], references: [id])
}

model ShiftSwapRequest {
  id           String   @id @default(uuid())
  tenantId     String?
  requesterId  String
  targetUserId String?
  shiftId      String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  acceptedById String?
  message      String?
  requester    User     @relation("SentSwaps", fields: [requesterId], references: [id])
  shift        Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("ReceivedSwaps", fields: [targetUserId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([targetUserId])
  @@index([tenantId, status])
}

model AgentRequest {
  id                  String    @id @default(uuid())
  tenantId            String?
  userId              String
  date                DateTime
  endDate             DateTime?
  startTime           String?
  endTime             String?
  hours               Float?
  code                String
  notes               String?
  status              String    @default("PENDING_OFFICER")
  reviewedBy          String?
  reviewedByOfficerId String?
  officerReviewedAt   DateTime?
  officerNotes        String?
  adminReviewedAt     DateTime?
  escalatedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  tenant              Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User      @relation("AgentRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model VacationPlan {
  id                  String                @id @default(uuid())
  tenantId            String?
  userId              String
  year                Int
  period              String
  startDate           DateTime
  endDate             DateTime
  status              String                @default("PREFERENCE")
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetVacationSwaps VacationSwapRequest[] @relation("TargetVacationSwapPlans")
  vacationSwaps       VacationSwapRequest[] @relation("VacationSwapPlans")

  @@unique([userId, period, year])
  @@index([tenantId, year])
}

model VacationSwapRequest {
  id                   String        @id @default(uuid())
  tenantId             String?
  requesterId          String
  targetUserId         String?
  acceptedById         String?
  vacationPlanId       String
  targetVacationPlanId String?
  status               String        @default("PENDING")
  message              String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  requester            User          @relation("SentVacationSwaps", fields: [requesterId], references: [id])
  targetUser           User?         @relation("ReceivedVacationSwaps", fields: [targetUserId], references: [id])
  targetVacationPlan   VacationPlan? @relation("TargetVacationSwapPlans", fields: [targetVacationPlanId], references: [id], onDelete: Cascade)
  tenant               Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vacationPlan         VacationPlan  @relation("VacationSwapPlans", fields: [vacationPlanId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([targetUserId])
  @@index([tenantId, status])
}

model VacationRotationPeriod {
  id             String                  @id @default(uuid())
  tenantId       String?
  season         String
  name           String
  startDay       Int
  startMonth     Int
  endDay         Int
  endMonth       Int
  orderIndex     Int                     @default(0)
  createdAt      DateTime                @default(now())
  rotationGroups VacationRotationGroup[] @relation("PeriodRotationGroups")
  tenant         Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, season, orderIndex])
  @@index([tenantId])
}

model VacationRotationGroup {
  id           String                 @id @default(uuid())
  tenantId     String?
  name         String
  season       String
  baseYear     Int
  basePeriodId String
  createdAt    DateTime               @default(now())
  basePeriod   VacationRotationPeriod @relation("PeriodRotationGroups", fields: [basePeriodId], references: [id])
  tenant       Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members      User[]                 @relation("VacationRotationGroupMembers")

  @@index([tenantId])
}

model HolidayRotationGroup {
  id         String   @id @default(uuid())
  tenantId   String?
  name       String
  baseYear   Int      @default(2026)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members    User[]   @relation("HolidayRotationGroupMembers")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model AgentBalance {
  id        String          @id @default(uuid())
  tenantId  String?
  userId    String
  year      Int
  deletedAt DateTime?
  tenant    Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User            @relation("AgentBalances", fields: [userId], references: [id], onDelete: Cascade)
  details   BalanceDetail[]

  @@unique([userId, year, tenantId])
}

model BalanceDetail {
  id           String       @id @default(uuid())
  balanceId    String
  code         String
  label        String?
  initialValue Float        @default(0)
  unit         String       @default("DAYS")
  balance      AgentBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  @@unique([balanceId, code])
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String?
  userId     String
  title      String
  message    String
  type       String    @default("INFO")
  link       String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  metadata   String?
  isArchived Boolean   @default(false)
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

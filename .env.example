# ============================================================================
# SENTINEL SECURITY SUITE — Environment Variables
# ============================================================================
# Copia questo file in .env e compila con i valori reali.
# NON COMMITARE MAI il file .env nel repository!
# ============================================================================

# === DATABASE (PostgreSQL — Supabase / Oracle) ===
# Pool connection (per le API route server-side, usa PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (per migrazioni Prisma)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# === POSTGRES DOCKER (solo per docker-compose.yml) ===
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="GENERA_CON_openssl_rand_-base64_32"
POSTGRES_DB="postgres"

# === AUTENTICAZIONE ===
# Genera con: openssl rand -base64 32
# DEVE essere una stringa casuale crittograficamente sicura (min 32 byte)
AUTH_SECRET="GENERA_CON_openssl_rand_-base64_32"
NEXTAUTH_SECRET="GENERA_CON_openssl_rand_-base64_32"
# URL canonico dell'app (con protocollo). In locale: http://localhost:3000
NEXTAUTH_URL="https://tuo-dominio.it"

# === HCAPTCHA (anti-bot login — obbligatorio in produzione) ===
# Registrati su https://hcaptcha.com e crea un sito per il tuo dominio
HCAPTCHA_SECRET_KEY="ES_..."
NEXT_PUBLIC_HCAPTCHA_SITE_KEY="00000000-0000-0000-0000-000000000000"

# === STORAGE SIGNED URL ===
# Genera con: openssl rand -hex 32
STORAGE_SIGNING_SECRET="GENERA_CON_openssl_rand_-hex_32"

# === VERBATEL INTEGRATION ===
# Genera con: openssl rand -hex 24
VERBATEL_API_KEY="GENERA_CON_openssl_rand_-hex_24"

# === EMAIL / PEC ===
PEC_SMTP_HOST="smtp.gmail.com"
PEC_SMTP_PORT="465"
PEC_SMTP_USER="tua-email@gmail.com"
PEC_SMTP_PASS="app-password-16-caratteri"
PEC_FROM="tua-email@gmail.com"

# === TELEGRAM BOT ===
# Crea un bot con @BotFather su Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrSTUvwxYZ"

# === PUSH NOTIFICATIONS (VAPID) ===
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BXXXXX..."
VAPID_PRIVATE_KEY="XXXXX..."
VAPID_SUBJECT="mailto:tua-email@esempio.it"

# === VERCEL/UPSTASH (opzionale — per rate limiting distribuito) ===
# DISABLE_UPSTASH=1           # Imposta a 1 per usare rate limit in-memory
# UPSTASH_REDIS_REST_URL=     # URL endpoint Upstash Redis
# UPSTASH_REDIS_REST_TOKEN=   # Token Upstash Redis

# === REDIS LOCALE (opzionale — alternativa a Upstash per Oracle) ===
# REDIS_URL="redis://127.0.0.1:6379"

# === CRON PROTECTION ===
# Genera con: openssl rand -hex 32
CRON_SECRET="GENERA_CON_openssl_rand_-hex_32"

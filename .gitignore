# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Custom ignores
*.db
*.db-journal
/tmp/
/scratch/
.vscode/

# Temp/build logs
*_out*.txt
*_errors*.txt
*.log
lint_*.txt
lint_*.json
lint_*.json.tmp

# Data files (never commit)
*.pdf
*.xlsx
*.xls
*.csv

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.vercel

.env*.local
.vercel
